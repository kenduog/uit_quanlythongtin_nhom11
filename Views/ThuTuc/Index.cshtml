@{
    ViewData["Title"] = "Thủ tục (Stored Procedure)";
}

<div class="d-flex align-items-center mb-3">
    <i class="bi bi-database-gear fs-3 text-primary me-2"></i>
    <div>
        <h3 class="mb-0">Demo Stored Procedure</h3>
        <small class="text-muted">Chọn một thủ tục để xem demo với dữ liệu thực tế từ SQL Server</small>
    </div>
</div>

<div class="row g-3">
    @{
        var dsThuTuc = new[]
        {
            ("LapPhieuMuon", "SP_LapPhieuMuon", "Lập phiếu mượn sách", "Kiểm tra thẻ + cuốn sách, tạo phiếu mượn, cập nhật 3 bảng.", "bi-clipboard-plus", "primary"),
            ("TraSach", "SP_TraSach", "Trả sách", "Ghi nhận ngày trả, tính phạt, đổi trạng thái kho.", "bi-box-arrow-in-left", "success"),
            ("ThuTienPhat", "SP_ThuTienPhat", "Thu tiền phạt", "Giảm nợ, tự mở khóa thẻ khi hết nợ.", "bi-cash-coin", "warning"),
            ("NhapSachKho", "SP_NhapSachKho", "Nhập sách vào kho", "Thêm cuốn sách mới theo đầu sách đã có.", "bi-box-seam", "info"),
            ("GiaHanThe", "SP_GiaHanThe", "Gia hạn thẻ", "Tăng thêm số tháng cho thẻ độc giả.", "bi-calendar-plus", "secondary"),
        };
    }
    @foreach (var (action, ten, tieuDe, mota, icon, color) in dsThuTuc)
    {
        <div class="col-md-6 col-lg-4">
            <a asp-action="@action" class="text-decoration-none">
                <div class="card h-100 border-start border-4 border-@color shadow-sm card-hover">
                    <div class="card-body d-flex align-items-start">
                        <div class="rounded-circle bg-@color bg-opacity-10 p-2 me-3 flex-shrink-0">
                            <i class="bi @icon fs-4 text-@color"></i>
                        </div>
                        <div>
                            <h6 class="card-title mb-1 text-dark">@tieuDe</h6>
                            <code class="small text-muted">@ten</code>
                            <p class="card-text text-muted small mt-1 mb-0">@mota</p>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<div class="mt-4 p-3 bg-light rounded border">
    <h6 class="mb-2"><i class="bi bi-info-circle me-1"></i>Hướng dẫn</h6>
    <ol class="mb-0 small text-muted">
        <li>Chọn một thủ tục ở trên để vào trang demo</li>
        <li>Xem bài toán, câu lệnh SQL, và dữ liệu hiện tại trong CSDL</li>
        <li>Nhập tham số và nhấn <b>Thực thi</b> để chạy stored procedure</li>
        <li>So sánh dữ liệu trước/sau để thấy kết quả</li>
    </ol>
</div>
