@model Nhom11.Models.ViewModels.ThuTucDemoViewModel
@{
    ViewData["Title"] = Model.TieuDe;
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Quay lại">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div class="flex-grow-1">
        <h4 class="mb-0">@Model.TieuDe</h4>
        <small class="text-muted">Demo thực thi đối tượng SQL trên dữ liệu thực</small>
    </div>
    <div>
        <button class="btn btn-sm btn-outline-secondary me-1" onclick="collapseAll()" title="Thu gọn tất cả">
            <i class="bi bi-arrows-collapse"></i>
        </button>
        <button class="btn btn-sm btn-outline-secondary" onclick="expandAll()" title="Mở rộng tất cả">
            <i class="bi bi-arrows-expand"></i>
        </button>
    </div>
</div>

<!-- Stepper -->
<div class="stepper">

    <!-- Bước 1: Bài toán -->
    <div class="stepper-item">
        <div class="stepper-marker bg-primary text-white">1</div>
        <div class="stepper-content">
            <div class="stepper-header" data-bs-toggle="collapse" data-bs-target="#step1" role="button">
                <h6 class="mb-0"><i class="bi bi-lightbulb me-1 text-primary"></i>Bài toán</h6>
                <i class="bi bi-chevron-down small text-muted"></i>
            </div>
            <div class="collapse show" id="step1">
                <div class="stepper-body">@Model.BaiToan</div>
            </div>
        </div>
    </div>

    <!-- Bước 2: Câu lệnh SQL -->
    <div class="stepper-item">
        <div class="stepper-marker bg-secondary text-white">2</div>
        <div class="stepper-content">
            <div class="stepper-header" data-bs-toggle="collapse" data-bs-target="#step2" role="button">
                <h6 class="mb-0"><i class="bi bi-code-square me-1 text-secondary"></i>Câu lệnh SQL</h6>
                <i class="bi bi-chevron-down small text-muted"></i>
            </div>
            <div class="collapse show" id="step2">
                <div class="stepper-body">
                    <pre class="bg-dark text-light rounded p-3 mb-0 small"><code>@Model.CauSql</code></pre>
                </div>
            </div>
        </div>
    </div>

    <!-- Bước 3: Dữ liệu TRƯỚC -->
    <div class="stepper-item">
        <div class="stepper-marker bg-info text-white">3</div>
        <div class="stepper-content">
            <div class="stepper-header" data-bs-toggle="collapse" data-bs-target="#step3" role="button">
                <h6 class="mb-0"><i class="bi bi-table me-1 text-info"></i>Dữ liệu <span class="badge bg-info">TRƯỚC</span></h6>
                <i class="bi bi-chevron-down small text-muted"></i>
            </div>
            <div class="collapse show" id="step3">
                <div class="stepper-body">
                    <div class="d-flex gap-1 mb-2">
                        <button class="btn btn-sm btn-outline-secondary" onclick="collapseGroup('#bang_b3')">
                            <i class="bi bi-dash-square me-1"></i>Thu gọn bảng
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="expandGroup('#bang_b3')">
                            <i class="bi bi-plus-square me-1"></i>Mở rộng bảng
                        </button>
                    </div>
                    <div id="bang_b3">
                        @foreach (var b in Model.BangTruoc)
                        {
                            <partial name="_Bang" model="b" />
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bước 4: Thực thi -->
    <div class="stepper-item">
        <div class="stepper-marker bg-primary text-white"><i class="bi bi-play-fill"></i></div>
        <div class="stepper-content">
            <div class="stepper-header" data-bs-toggle="collapse" data-bs-target="#step4" role="button">
                <h6 class="mb-0"><i class="bi bi-terminal me-1 text-primary"></i>Thực thi</h6>
                <i class="bi bi-chevron-down small text-muted"></i>
            </div>
            <div class="collapse show" id="step4">
                <div class="stepper-body">
                    <form asp-action="@Model.ActionName" method="post">
                        <div class="row g-3">
                            @foreach (var t in Model.Truong)
                            {
                                var val = Model.GiaTri.TryGetValue(t.Ten, out var v) ? v : null;
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label fw-semibold small">@t.Nhan</label>
                                    @if (t.Loai == "select")
                                    {
                                        @if (t.TaiLaiKhiDoi)
                                        {
                                            <select name="@t.Ten" class="form-select form-select-sm" asp-items="t.Options"
                                                    onchange="location.href='@Url.Action(Model.ActionName)?@(t.Ten)=' + encodeURIComponent(this.value)"></select>
                                        }
                                        else
                                        {
                                            <select name="@t.Ten" class="form-select form-select-sm" asp-items="t.Options"></select>
                                        }
                                    }
                                    else if (t.Loai == "number")
                                    {
                                        <input name="@t.Ten" type="number" min="0" step="any" value="@val" class="form-control form-control-sm" required />
                                    }
                                    else if (t.Loai == "date")
                                    {
                                        <input name="@t.Ten" type="date" value="@val" class="form-control form-control-sm" required />
                                    }
                                    else
                                    {
                                        <input name="@t.Ten" type="text" value="@val" class="form-control form-control-sm" required />
                                    }
                                    @if (!string.IsNullOrEmpty(t.GhiChu))
                                    {
                                        <div class="form-text small">@t.GhiChu</div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-play-circle me-1"></i>Thực thi câu lệnh
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Bước 5: Kết quả SAU -->
    @if (Model.BangSau != null)
    {
        <div class="stepper-item">
            <div class="stepper-marker bg-@(Model.ThanhCong == true ? "success" : "danger") text-white">
                <i class="bi bi-@(Model.ThanhCong == true ? "check-lg" : "x-lg")"></i>
            </div>
            <div class="stepper-content">
                <div class="stepper-header" data-bs-toggle="collapse" data-bs-target="#step5" role="button">
                    <h6 class="mb-0">
                        <i class="bi bi-@(Model.ThanhCong == true ? "check-circle" : "exclamation-circle") me-1 text-@(Model.ThanhCong == true ? "success" : "danger")"></i>
                        Kết quả <span class="badge bg-@(Model.ThanhCong == true ? "success" : "danger")">SAU</span>
                    </h6>
                    <i class="bi bi-chevron-down small text-muted"></i>
                </div>
                <div class="collapse show" id="step5">
                    <div class="stepper-body">
                        <div class="alert alert-@(Model.ThanhCong == true ? "success" : "danger") d-flex align-items-start">
                            <i class="bi bi-@(Model.ThanhCong == true ? "check-circle-fill" : "exclamation-triangle-fill") me-2 mt-1"></i>
                            <div style="white-space: pre-line">@Model.Output</div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small fw-semibold">Dữ liệu sau khi thực thi:</span>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-secondary" onclick="collapseGroup('#bang_b5')" title="Thu gọn">
                                    <i class="bi bi-dash-square"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" onclick="expandGroup('#bang_b5')" title="Mở rộng">
                                    <i class="bi bi-plus-square"></i>
                                </button>
                            </div>
                        </div>
                        <div id="bang_b5">
                            @foreach (var b in Model.BangSau)
                            {
                                <partial name="_Bang" model="b" />
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@section Scripts {
<script>
    function collapseGroup(selector) {
        document.querySelectorAll(selector + ' .collapse').forEach(el => {
            bootstrap.Collapse.getOrCreateInstance(el, { toggle: false }).hide();
        });
    }
    function expandGroup(selector) {
        document.querySelectorAll(selector + ' .collapse').forEach(el => {
            bootstrap.Collapse.getOrCreateInstance(el, { toggle: false }).show();
        });
    }
    function collapseAll() {
        document.querySelectorAll('.stepper .collapse').forEach(el => {
            bootstrap.Collapse.getOrCreateInstance(el, { toggle: false }).hide();
        });
    }
    function expandAll() {
        document.querySelectorAll('.stepper .collapse').forEach(el => {
            bootstrap.Collapse.getOrCreateInstance(el, { toggle: false }).show();
        });
    }
</script>
}