@model Dausach
@{
    ViewData["Title"] = "Sửa đầu sách";
}

<h2>Sửa đầu sách: @Model.MaDauSach</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.MaDauSach" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MaDauSach" />
            <div class="mb-3">
                <label class="form-label">Tên sách</label>
                <input asp-for="TenSach" class="form-control" />
                <span asp-validation-for="TenSach" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Tác giả</label>
                <input asp-for="TacGia" class="form-control" />
                <span asp-validation-for="TacGia" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Thể loại</label>
                <input asp-for="TheLoai" class="form-control" />
                <span asp-validation-for="TheLoai" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
