@model PagedResult<Dausach>
@{
    ViewData["Title"] = "Quản lý đầu sách";
    var tuKhoa = ViewBag.TuKhoa as string;
    var theLoai = ViewBag.TheLoai as string;
    var dsTheLoai = ViewBag.DanhSachTheLoai as List<string> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Đầu sách</h2>
    <a class="btn btn-success" asp-action="Create">+ Thêm đầu sách</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="tuKhoa" value="@tuKhoa" class="form-control" placeholder="Tìm theo tên sách / tác giả / mã" />
    </div>
    <div class="col-md-3">
        <select name="theLoai" class="form-select">
            <option value="">-- Tất cả thể loại --</option>
            @foreach (var t in dsTheLoai)
            {
                <option value="@t" selected="@(t == theLoai)">@t</option>
            }
        </select>
    </div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Tìm kiếm</button></div>
    <div class="col-md-2"><a class="btn btn-outline-secondary w-100" asp-action="Index">Xóa lọc</a></div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Mã</th><th>Tên sách</th><th>Tác giả</th><th>Thể loại</th><th class="text-end">Thao tác</th></tr>
    </thead>
    <tbody>
        @if (!Model.Items.Any())
        {
            <tr><td colspan="5" class="text-center text-muted py-3">Không có dữ liệu.</td></tr>
        }
        @foreach (var d in Model.Items)
        {
            <tr>
                <td>@d.MaDauSach</td>
                <td>@d.TenSach</td>
                <td>@d.TacGia</td>
                <td><span class="badge bg-secondary">@d.TheLoai</span></td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@d.MaDauSach">Xem</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@d.MaDauSach">Sửa</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@d.MaDauSach">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    ViewData["RouteValues"] = new Dictionary<string, string?> { ["tuKhoa"] = tuKhoa, ["theLoai"] = theLoai };
}
<partial name="_Pager" model="Model" />
