@model PagedResult<Cuonsach>
@{
    ViewData["Title"] = "Quản lý cuốn sách";
    var maDauSach = ViewBag.MaDauSach as string;
    var trangThaiKho = ViewBag.TrangThaiKho as string;
    var dauSachList = ViewBag.DauSachList as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Cuốn sách</h2>
    <a class="btn btn-success" asp-action="Create">+ Thêm cuốn sách</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <select name="maDauSach" class="form-select" asp-items="dauSachList">
            <option value="">-- Tất cả đầu sách --</option>
        </select>
    </div>
    <div class="col-md-3">
        <select name="trangThaiKho" class="form-select">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Còn trong kho" selected="@(trangThaiKho == "Còn trong kho")">Còn trong kho</option>
            <option value="Đã cho mượn" selected="@(trangThaiKho == "Đã cho mượn")">Đã cho mượn</option>
        </select>
    </div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Lọc</button></div>
    <div class="col-md-2"><a class="btn btn-outline-secondary w-100" asp-action="Index">Xóa lọc</a></div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Mã cuốn</th><th>Tên sách</th><th>Trạng thái kho</th><th>Hiện trạng</th><th class="text-end">Thao tác</th></tr>
    </thead>
    <tbody>
        @if (!Model.Items.Any())
        {
            <tr><td colspan="5" class="text-center text-muted py-3">Không có dữ liệu.</td></tr>
        }
        @foreach (var c in Model.Items)
        {
            <tr>
                <td>@c.MaCuonSach</td>
                <td>@c.MaDauSachNavigation?.TenSach</td>
                <td>
                    @if (c.TrangThaiKho == "Còn trong kho")
                    {
                        <span class="badge bg-success">@c.TrangThaiKho</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">@c.TrangThaiKho</span>
                    }
                </td>
                <td>@c.HienTrangSach</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@c.MaCuonSach">Xem</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.MaCuonSach">Sửa</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@c.MaCuonSach">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    ViewData["RouteValues"] = new Dictionary<string, string?> { ["maDauSach"] = maDauSach, ["trangThaiKho"] = trangThaiKho };
}
<partial name="_Pager" model="Model" />
