@model Cuonsach
@{
    ViewData["Title"] = "Thêm cuốn sách";
    var dauSachList = ViewBag.DauSachList as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<h2>Thêm cuốn sách</h2>
<p class="text-muted">Mã cuốn sách được sinh tự động theo đầu sách.</p>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label class="form-label">Đầu sách</label>
                <select asp-for="MaDauSach" class="form-select" asp-items="dauSachList">
                    <option value="">-- Chọn đầu sách --</option>
                </select>
                <span asp-validation-for="MaDauSach" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Trạng thái kho</label>
                <select asp-for="TrangThaiKho" class="form-select">
                    <option value="Còn trong kho">Còn trong kho</option>
                    <option value="Đã cho mượn">Đã cho mượn</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Hiện trạng sách</label>
                <select asp-for="HienTrangSach" class="form-select">
                    <option value="Bình thường">Bình thường</option>
                    <option value="Hư">Hư</option>
                    <option value="Mất">Mất</option>
                </select>
            </div>
            <button type="submit" class="btn btn-success">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
