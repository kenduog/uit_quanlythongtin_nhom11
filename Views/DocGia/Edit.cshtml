@model Docgium
@{
    ViewData["Title"] = "Sửa độc giả";
}

<h2>Sửa độc giả: @Model.MaDocGia</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.MaDocGia" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MaDocGia" />
            <div class="mb-3">
                <label class="form-label">Họ tên</label>
                <input asp-for="HoTen" class="form-control" />
                <span asp-validation-for="HoTen" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Ngày lập thẻ</label>
                <input asp-for="NgayLapThe" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Ngày hết hạn</label>
                <input asp-for="NgayHetHan" type="date" class="form-control" />
                <span asp-validation-for="NgayHetHan" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Tổng nợ</label>
                <input asp-for="TongNo" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Trạng thái</label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="Bình thường">Bình thường</option>
                    <option value="Bị khóa">Bị khóa</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
