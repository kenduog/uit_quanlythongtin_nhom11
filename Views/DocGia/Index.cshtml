@model PagedResult<Docgium>
@{
    ViewData["Title"] = "Quản lý độc giả";
    var tuKhoa = ViewBag.TuKhoa as string;
    var trangThai = ViewBag.TrangThai as string;
    var homNay = (DateOnly)ViewBag.HomNay;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Độc giả</h2>
    <a class="btn btn-success" asp-action="Create">+ Thêm độc giả</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="tuKhoa" value="@tuKhoa" class="form-control" placeholder="Tìm theo họ tên / mã độc giả" />
    </div>
    <div class="col-md-3">
        <select name="trangThai" class="form-select">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Bình thường" selected="@(trangThai == "Bình thường")">Bình thường</option>
            <option value="Bị khóa" selected="@(trangThai == "Bị khóa")">Bị khóa</option>
        </select>
    </div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Tìm</button></div>
    <div class="col-md-2"><a class="btn btn-outline-secondary w-100" asp-action="Index">Xóa lọc</a></div>
</form>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr><th>Mã</th><th>Họ tên</th><th>Ngày hết hạn</th><th class="text-end">Tổng nợ</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr>
    </thead>
    <tbody>
        @if (!Model.Items.Any())
        {
            <tr><td colspan="6" class="text-center text-muted py-3">Không có dữ liệu.</td></tr>
        }
        @foreach (var d in Model.Items)
        {
            var hetHan = d.NgayHetHan < homNay;
            <tr>
                <td>@d.MaDocGia</td>
                <td>@d.HoTen</td>
                <td class="@(hetHan ? "text-danger fw-bold" : "")">
                    @d.NgayHetHan.ToString("dd/MM/yyyy")
                    @if (hetHan) { <span class="badge bg-danger">Hết hạn</span> }
                </td>
                <td class="text-end">@((d.TongNo ?? 0).ToString("N0"))đ</td>
                <td>
                    @if (d.TrangThai == "Bị khóa")
                    {
                        <span class="badge bg-danger">Bị khóa</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Bình thường</span>
                    }
                </td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@d.MaDocGia">Xem</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@d.MaDocGia">Sửa</a>
                    <form asp-action="DoiTrangThai" asp-route-id="@d.MaDocGia" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm @(d.TrangThai == "Bị khóa" ? "btn-outline-success" : "btn-outline-warning")">
                            @(d.TrangThai == "Bị khóa" ? "Mở khóa" : "Khóa")
                        </button>
                    </form>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@d.MaDocGia">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    ViewData["RouteValues"] = new Dictionary<string, string?> { ["tuKhoa"] = tuKhoa, ["trangThai"] = trangThai };
}
<partial name="_Pager" model="Model" />
